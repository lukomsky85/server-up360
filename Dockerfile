# ============================================================================
# 🐳 Dockerfile for Feedback Server
# База: Python 3.11 Slim (оптимизировано для размера)
# ============================================================================
FROM python:3.11-slim

# Метаданные
LABEL maintainer="dev-team"
LABEL description="Feedback Server API with PostgreSQL support"

# Рабочая директория внутри контейнера
WORKDIR /app

# ============================================================================
# 🛠️ Установка системных зависимостей
# gcc и libpq-dev нужны для компиляции psycopg2 (драйвер PostgreSQL)
# curl нужен для Healthcheck
# ============================================================================
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
    curl \
    && rm -rf /var/lib/apt/lists/*

# ============================================================================
# 🐍 Установка Python зависимостей
# Копируем только requirements.txt, чтобы кэшировать этот слой
# ============================================================================
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# ============================================================================
# 📂 Копирование исходного кода
# ============================================================================
COPY . .

# ============================================================================
# ⚙️ Настройка окружения
# PYTHONUNBUFFERED=1 критически важен для корректного вывода логов в Docker
# ============================================================================
ENV PYTHONUNBUFFERED=1
ENV FLASK_APP=app.py
ENV FLASK_ENV=production

# Создание папок для логов и instance (если их нет в gitignore)
RUN mkdir -p /app/instance /app/logs

# ============================================================================
# 🚪 Проброс порта
# ============================================================================
EXPOSE 5001

# ============================================================================
# 🏥 Healthcheck (Проверка живучести контейнера)
# Docker будет опрашивать этот URL каждые 30 секунд
# ============================================================================
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:5001/api/v1/health || exit 1

# ============================================================================
# 🚀 Запуск приложения (Production Mode)
# Используем Gunicorn с 4 воркерами и 2 потоками на воркер
# Формат "app:create_app()" позволяет использовать Factory Pattern
# ============================================================================
CMD ["gunicorn", \
     "--bind", "0.0.0.0:5001", \
     "--workers", "4", \
     "--threads", "2", \
     "--access-logfile", "-", \
     "--error-logfile", "-", \
     "app:create_app()"]
